%% 1. Import Data
data = readtable('water_quality_CA.csv');  % your trimmed CSV

%% 2. User Input
disp('Available cities:')
disp(unique(data.City))

cityInput = input('Enter a city name: ', 's');

%% 3. Filter for chosen city
cityData = data(strcmpi(data.City, cityInput), :);

if isempty(cityData)
    disp('City not found. Please check spelling.')
    return
end

%% 4. Call user-defined function
[ratingLabels, scores] = qualityRating(cityData.MeasuredValue, cityData.Guideline);

%% 5. Display results table
disp('--- Water Quality Summary ---')
disp(table(cityData.Contaminant, cityData.MeasuredValue, ...
           cityData.Guideline, ratingLabels', ...
           'VariableNames', {'Contaminant','Measured','Guideline','Rating'}))

