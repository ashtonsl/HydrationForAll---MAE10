function [labels, scores] = qualityRating(measured, guidelines)
% qualityRating - Classifies each contaminant as OK, Borderline, or High Concern
% Inputs:  measured   - vector of measured contaminant values
%          guidelines - vector of EPA/CA guideline limits
% Outputs: labels     - cell array of rating strings
%          scores     - numeric risk score (0, 1, or 2)

n = length(measured);
labels = cell(1, n);
scores = zeros(1, n);

for i = 1:n
    ratio = measured(i) / guidelines(i);
    if ratio <= 0.5
        labels{i} = 'OK';
        scores(i) = 0;
    elseif ratio <= 1.0
        labels{i} = 'Borderline';
        scores(i) = 1;
    else
        labels{i} = 'High Concern';
        scores(i) = 2;
    end
end
end
